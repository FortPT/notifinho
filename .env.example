# Production Compose defaults. Copy to .env and adjust on the deployment host.
NOTIFINHO_IMAGE=fortpt/notifinho:1.9.7
NOTIFINHO_UID=1000
NOTIFINHO_GID=1000
NOTIFINHO_SMTP_PORT=8025
NOTIFINHO_HTTP_PORT=18080
NOTIFINHO_CONFIG_DIR=./config
NOTIFINHO_LOG_DIR=./logs
NOTIFINHO_SECRETS_DIR=./secrets
TZ=Europe/Lisbon

# Keep real values only in the untracked .env file or Docker secrets.
NOTIFINHO_SMTP_PASSWORD=
NOTIFINHO_ADMIN_TOKEN=
NOTIFINHO_HARDWARE_TOKEN=
